# Application
APP_NAME=doc-agent
DEBUG=false

# MySQL
MYSQL_URL=mysql+aiomysql://user:password@localhost:3306/docagent

# Redis
REDIS_URL=redis://localhost:6379/0

# Milvus
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_ALIAS=default

# Knowledge base
KNOWLEDGE_BASE_VERSION=v1

# LLM semaphore limits (JSON object)
LLM_SEMAPHORE_LIMITS={"interactive": 5, "background": 2, "audit": 1}

# Redis Streams MQ
MQ_STREAM_NAME=doc-agent:tasks
MQ_CONSUMER_GROUP=doc-agent-workers
# MQ_CONSUMER_NAME is auto-generated as "{hostname}-{pid}" if not set
