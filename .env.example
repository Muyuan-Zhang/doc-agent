# Application
APP_NAME=doc-agent
DEBUG=false

# PostgreSQL — docker-compose default: docagent/docagent
POSTGRES_URL=postgresql+asyncpg://docagent:docagent@localhost:5432/docagent

# Redis
REDIS_URL=redis://localhost:6379/0

# Milvus
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_ALIAS=default

# Knowledge base
KNOWLEDGE_BASE_VERSION=v1
CHUNK_SIZE=512
CHUNK_OVERLAP=64
EMBEDDING_DIM=1536
EMBEDDING_BATCH_SIZE=100
MILVUS_KB_COLLECTION=knowledge_base

# LLM / Embedding
OPENAI_API_KEY=sk-...
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_CHAT_MODEL=gpt-4o-mini

# LLM semaphore limits (nested via __ delimiter)
LLM_SEMAPHORE_LIMITS__INTERACTIVE=5
LLM_SEMAPHORE_LIMITS__BACKGROUND=2
LLM_SEMAPHORE_LIMITS__AUDIT=1

# Memory (M5)
MEMORY_RECENT_MAX_TURNS=20
MEMORY_RECENT_TTL_SECONDS=86400
MEMORY_SUMMARY_THRESHOLD=15
MEMORY_MILVUS_COLLECTION=memory_vectors

# Redis Streams MQ
MQ_STREAM_NAME=doc-agent:tasks
MQ_CONSUMER_GROUP=doc-agent-workers
# MQ_CONSUMER_NAME is auto-generated as "{hostname}-{pid}" if not set

# M2 Retrieval
BM25_TOP_K=20
VECTOR_TOP_K=20
RRF_K=60
RERANK_TOP_N=10
FINAL_TOP_K=5

# M3 RAG Cache
CACHE_TTL_SECONDS=3600
CACHE_AUTO_APPROVE_THRESHOLD=3
CACHE_REWRITE_ENABLED=true
CACHE_MAX_PENDING_REVIEWS=100
# CACHE_API_KEY: required for cache approve/reject/delete; leave empty to disable auth
CACHE_API_KEY=

# M4 Agent
AGENT_MAX_RETRIES=3
AGENT_JOB_TTL_SECONDS=3600
STREAM_HEARTBEAT_INTERVAL=15.0
AGENT_RATE_LIMIT_RPM=20

# M6 Consistency
CONSISTENCY_CONSUMER_GROUP=doc-agent-consistency
# CONSISTENCY_CONSUMER_NAME is auto-generated as "{hostname}-{pid}-consistency" if not set
CACHE_RAG_NAMESPACE=rag
CACHE_INVALIDATION_SCAN_BATCH=100
CACHE_INVALIDATION_MAX_ITERATIONS=1000
